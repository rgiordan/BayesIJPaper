EvalMrp <- function(pi, y) {
reg_data <-
as.data.frame(x_mat) %>%
mutate(y=y)
reg <- lm(y ~ V1 + V2 - 1, reg_data)
yhat <- predict(reg, reg_data)
return(sum(pi * yhat))
}
y_flip <- y
y_flip[i_target]  <- -1 * y[i_target]
sign(y[i_target])
EvalMrp(pi, y)
EvalMrp(pi, y) - EvalMrp(pi, y_flip)
y[i_target] - y_flip[i_target]
EvalMrp(pi, y) - EvalMrp(pi, y_flip)
