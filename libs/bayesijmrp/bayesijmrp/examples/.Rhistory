ProjOntoX <- function(v) {
xtx_inv_v <- solve(xtx, t(x_mat) %*% v)
return(x_mat %*% xtx_inv_v)
}
x_svd <- svd(x_mat)
ProjOntoXSvd <- function(v) {
# This only depends on the left singular vectors, not the singular values.
u_v <- t(x_svd$u) %*% v
return(x_svd$u %*% u_v)
}
v <- runif(n_obs)
v_x <- ProjOntoX(v)
