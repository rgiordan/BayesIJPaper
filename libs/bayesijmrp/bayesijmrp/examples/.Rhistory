# Construct a population weight vector whose first affine weight is negative.
# If the weight vector is \sum_p a_p e_p, then the i-th entry of the projection
# is \sum_p a_p < U_{i.}, U_{p.}>.  So to make the i-th entry of the affine
# weight negative, make a_p large when < U_{i.}, U_{p.}> is negative.
x_u <- x_svd$u
i_target <- 1
u_inner <- sapply(1:n_obs, \(n) sum(x_u[i_target, ] * x_u[n, ]))
summary(u_inner)
w_ratio <- -1 * sum(u_inner[u_inner > 0]) / sum(u_inner[u_inner < 0])
pi <- ifelse(u_inner < 0, 2 * w_ratio, 1)
# Sanity check
stopifnot(ProjOntoX(pi)[1] < 0)
stopifnot(EvalLInf(sum(pi * u_inner) - ProjOntoX(pi)[1]) < 1e-8)
ProjOntoX(pi)[1]
summary(ProjOntoX(pi))
summary(pi)
