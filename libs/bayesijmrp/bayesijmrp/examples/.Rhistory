###########################################################
# Demonstrate with a correctly specified regression.
# That the weight is negative is in fact invariant to y,
# so the response doesn't matter.  But I'll just show it for completeness.
beta <- c(1, 2)
y_mean <- x_mat %*% beta
y <- rnorm(n_obs) + y_mean
EvalMrp <- function(pi, y) {
reg_data <-
as.data.frame(x_mat) %>%
mutate(y=y)
reg <- lm(y ~ V1 + V2 - 1, reg_data)
yhat <- predict(reg, reg_data)
return(sum(pi * yhat) / sum(pi))
}
y_flip <- y
y_flip[i_target]  <- -1 * y[i_target]
# MrP moves in the opposite direction as the change in y,
# as expected with a negative weight.
y[i_target] - y_flip[i_target]
EvalMrp(pi, y) - EvalMrp(pi, y_flip)
stopifnot(sign(y[i_target] - y_flip[i_target]) != sign(EvalMrp(pi, y) - EvalMrp(pi, y_flip)))
