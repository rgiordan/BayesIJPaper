\newcommand{\MRPGraph}{
<<graph_fig_cap14>>=
SetImageSize(aspect_ratio=5/10)
figcap <- paste0("Covariance estimates for the MrP model. ",
                 "The dots are the estimates computed on the single dataset ",
                 "chosen as the basis for bootstrapping. ",
                 "The boxplots show the spread of the IJ and ",
                 "posterior covariance across simulations, which ",
                 "includes both frequentist and MCMC variability. ",
                 "The horizontal line shows the true sampling variance ",
                 "as estimated by simulation.")
@
<<mrp_graph, cache=knitr_cache, fig.show='hold', fig.cap=figcap>>=
SourceFile("R_scripts/mrp/result_graph.R",
           echo=knitr_debug, print.eval=TRUE)
@
}


\newcommand{\MRPMAPGraph}{
<<graph_fig_cap15>>=
SetImageSize(aspect_ratio=5/10)
figcap <- paste0("MAP versus MCMC for the MrP model")
@
<<mrp_map_graph, cache=knitr_cache, fig.show='hold', fig.cap=figcap>>=
SourceFile("R_scripts/mrp/map_graph.R",
           echo=knitr_debug, print.eval=TRUE)
@
}




